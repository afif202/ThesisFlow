{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "supervisor"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Repository": {
      "title": "Thesis Repository",
      "description": "A repository containing thesis versions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Commit": {
      "title": "Commit/Version",
      "description": "A specific version of a thesis document.",
      "type": "object",
      "properties": {
        "repoId": { "type": "string" },
        "authorId": { "type": "string" },
        "message": { "type": "string" },
        "abstract": { "type": "string" },
        "hash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["repoId", "authorId", "message"]
    },
    "AIInsight": {
      "title": "AI Insight",
      "description": "Automated analysis results for a specific commit.",
      "type": "object",
      "properties": {
        "commitId": { "type": "string" },
        "confidenceScores": { "type": "object" },
        "keywords": { "type": "array" },
        "rationale": { "type": "string" },
        "fieldDistribution": { "type": "array" },
        "analyzedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["commitId", "confidenceScores"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles by UID" },
    "/repositories/{repoId}": { "schema": "Repository", "description": "Thesis repositories" },
    "/repositories/{repoId}/commits/{commitId}": { "schema": "Commit", "description": "Commits within a repository" },
    "/ai_insights/{insightId}": { "schema": "AIInsight", "description": "AI analysis logs" }
  }
}
