rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) && data.keys().size() <= 6
        && data.email is string && data.email.size() <= 256
        && data.role in ['student', 'supervisor']
        && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128)
        && (data.get('avatarUrl', '') is string && data.get('avatarUrl', '').size() <= 512);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'student';
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().role == existing().role
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatarUrl']);
    }

    // --- Repositories ---
    function isValidRepository(data) {
      return data.keys().hasAll(['name', 'ownerId']) && data.keys().size() <= 8
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.ownerId == request.auth.uid
        && (data.get('description', '') is string && data.get('description', '').size() <= 500);
    }

    match /repositories/{repoId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidRepository(incoming()) && isValidId(repoId);
      allow update: if isOwner(existing().ownerId) && isValidRepository(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'updatedAt']);
      allow delete: if isOwner(existing().ownerId);

      // --- Commits ---
      function isValidCommit(data, currentRepoId) {
        return data.keys().hasAll(['repoId', 'authorId', 'message']) && data.keys().size() <= 10
          && data.repoId == currentRepoId
          && data.authorId == request.auth.uid
          && data.message is string && data.message.size() <= 200
          && (data.get('abstract', '') is string && data.get('abstract', '').size() <= 5000);
      }

      match /commits/{commitId} {
        allow list, get: if isSignedIn();
        allow create: if isOwner(get(/databases/$(database)/documents/repositories/$(repoId)).data.ownerId) 
          && isValidCommit(incoming(), repoId) && isValidId(commitId);
        allow update: if false;
        allow delete: if isOwner(get(/databases/$(database)/documents/repositories/$(repoId)).data.ownerId);
      }
    }

    // --- AI Insights ---
    function isValidAIInsight(data) {
      return data.keys().hasAll(['commitId', 'confidenceScores']) && data.keys().size() <= 10
        && data.commitId is string && data.commitId.size() <= 128
        && data.confidenceScores is map;
    }

    match /ai_insights/{insightId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.commitId != null;
      allow create, update: if isSignedIn();
    }
  }
}
